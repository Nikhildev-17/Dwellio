<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h3>Edit Your Listing</h3>
    <form action="/listings/<%= oldListing._id %>?_method=PUT" method = "POST">
        <input type="text" name = "title" value = "<%= oldListing.title %>">
        <br><br>
        <textarea type="text" name = "description" value = "<%= oldListing.description %>"></textarea>
        <br><br>
        <input type="number" name = "price" value = "<%= oldListing.price %>">
        <br><br>
        <input type="text" name = "image" value = "<%= oldListing.image.url %>" >
        <br><br>
        <input type="text" name = "location" value = "<%= oldListing.location %>">
        <br><br>
        <input type="text" name = "country" value = "<%= oldListing.country %>">
        <br><br>
        <button>Add</button>
    </form>
</body>
</html>