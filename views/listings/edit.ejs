<% layout("layouts/boilerplate") %>
<body>

    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">

                <div class="card shadow-sm border-0 p-4">
                    <h3 class="mb-4 text-center">Edit your Listing</h3>

                    <form action="/listings/<%= oldListing._id %>?_method=PUT" method="POST" novalidate class = "needs-validation">

                    <div class="mb-3">
                        <label class="form-label">Title</label>
                        <input type="text" name="title" class="form-control" value = "<%= oldListing.title %>" required>
                        <div class="invalid-feedback">Please Select another title!</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea name="description" class="form-control" value = "<%= oldListing.description %>" rows="3" required></textarea>
                        <div class="invalid-feedback">Please give some appropriate decsription!</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Image URL</label>
                        <input type="text" name="image[url]" class="form-control" required>
                        <div class="invalid-feedback">Enter a Valid Image URL</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Price</label>
                        <input type="number" name="price" class="form-control" value = "<%= oldListing.price %>" required>
                        <div class="invalid-feedback">Please Enter a Valid Price</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Location</label>
                        <input type="text" name="location" class="form-control" value = "<%= oldListing.location %>" required>
                        <div class="invalid-feedback">Please Enter a valid location</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Country</label>
                        <input type="text" name="country" class="form-control" value = "<%= oldListing.country %>" required>
                        <div class="invalid-feedback">Please Enter a valid Country!</div>
                    </div>

                    <button class="btn btn-primary w-100 mt-3">
                        Submit
                    </button>

                    </form>
                </div>

            </div>
        </div>
    </div>

</body>
